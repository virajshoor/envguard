{
  "name": "@virajshoor/envguard",
  "version": "1.3.0",
  "description": "Validate .env files against a typed .env.schema before bad config breaks your deploy.",
  "main": "lib/index.js",
  "bin": {
    "envguard": "bin/envguard.js"
  },
  "files": [
    "action.yml",
    "bin/",
    "examples/",
    "lib/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node --check bin/envguard.js && node --check lib/index.js && node --check lib/parser.js && node --check lib/validator.js && node --check lib/reporter.js && node --check lib/presets.js && node --check lib/secrets.js && node --check test/*.test.js",
    "smoke": "node bin/envguard.js check --env examples/.env.example --schema examples/.env.schema.example --strict --secrets",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "env",
    "dotenv",
    "schema",
    "validation",
    "validator",
    "environment",
    "config",
    "configuration",
    "cli",
    "ci",
    "devops",
    "github-actions",
    "json"
  ],
  "author": "virajshoor",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virajshoor/envguard.git"
  },
  "bugs": {
    "url": "https://github.com/virajshoor/envguard/issues"
  },
  "homepage": "https://github.com/virajshoor/envguard#readme",
  "engines": {
    "node": ">=18.3.0"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  }
}
